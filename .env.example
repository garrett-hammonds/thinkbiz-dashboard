# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DIRECTOR_INVITE_SECRET=

# --- Notifications ---

# Email (Resend) — create a key at https://resend.com and verify your sending domain
RESEND_API_KEY=
EMAIL_FROM="ThinkBiz Solutions <notifications@yourdomain.com>"

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY, exposed to the browser for subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=

# Shared secret the Supabase Database Webhook sends as the `x-webhook-secret` header
CHAT_WEBHOOK_SECRET=

# --- Abuse protection for the public forms (visitor check-in + apply) ---
# Both are OPTIONAL: when unset, rate limiting / CAPTCHA are disabled and the
# forms work as before. Set them in production to throttle automated abuse.

# Rate limiting via Upstash Redis / Vercel KV (https://upstash.com). The REST
# URL + token from the database's "REST API" section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile CAPTCHA (https://developers.cloudflare.com/turnstile/).
# Site key is public (rendered in the browser); secret key verifies server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Visitor check-in form ---
# Optional. The visitor check-in form (/visit/<clubId>) always writes to the
# Supabase `visitors` table; if set, it ALSO forwards each entry to Formspree
# for an email/dashboard copy. Falls back to the live form endpoint when unset,
# so you only need this to point it somewhere else.
FORMSPREE_VISITOR_ENDPOINT=https://formspree.io/f/mgojolqz

# --- Membership billing (Stripe) ---
# Billing stays OFF (no paywall) until BOTH STRIPE_SECRET_KEY and STRIPE_PRICE_ID
# are set. See docs/BILLING_SETUP.md for the full walkthrough.

# Secret key from https://dashboard.stripe.com/apikeys (use a test key in dev)
STRIPE_SECRET_KEY=
# The recurring Price ID for the membership (looks like price_...)
STRIPE_PRICE_ID=
# Signing secret for the Stripe webhook endpoint (whsec_...). From the webhook's
# dashboard page, or printed by `stripe listen` in local dev.
STRIPE_WEBHOOK_SECRET=

# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DIRECTOR_INVITE_SECRET=

# --- Notifications ---

# Email (Resend) — create a key at https://resend.com and verify your sending domain
RESEND_API_KEY=
EMAIL_FROM="ThinkBiz Solutions <notifications@yourdomain.com>"

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY, exposed to the browser for subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=

# Shared secret the Supabase Database Webhook sends as the `x-webhook-secret` header
CHAT_WEBHOOK_SECRET=
